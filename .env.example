# Copy to .env and fill in real values. Never commit .env.

# Required: 64+ random hex chars. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=replace_me_with_64_plus_hex_chars

# Required: same-origin canonical URL used for CSRF origin check.
# Production: https://spilltea.com
# Local dev:  http://localhost:3000
PUBLIC_ORIGIN=http://localhost:3000

# Port the server listens on.
PORT=3000

# Node environment: production | development
NODE_ENV=production

# Cookie secure flag. Force "true" in production with HTTPS. Leave empty for auto.
# COOKIE_SECURE=true

# Trust proxy depth if behind a reverse proxy (Nginx/Cloudflare). Use 1 for one proxy.
TRUST_PROXY=1

# Max image upload size in MB.
MAX_UPLOAD_MB=5
