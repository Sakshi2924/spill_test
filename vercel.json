{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "trailingSlash": false,
  "cleanUrls": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options",      "value": "nosniff" },
        { "key": "X-Frame-Options",             "value": "DENY" },
        { "key": "Referrer-Policy",             "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy",          "value": "geolocation=(), microphone=(), camera=()" },
        { "key": "Strict-Transport-Security",   "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "Content-Security-Policy",     "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdnjs.cloudflare.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self' data:; connect-src 'self'; object-src 'none'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'" }
      ]
    },
    {
      "source": "/(.*\\.html)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, must-revalidate" }
      ]
    },
    {
      "source": "/main%20images/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=604800, immutable" }
      ]
    },
    {
      "source": "/(Spill\\.png|ChompRegular-V4Dge\\.otf|ChompOblique-JpByK\\.ttf|robots\\.txt|sitemap\\.xml)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, must-revalidate" }
      ]
    }
  ],
  "redirects": [
    { "source": "/admin",              "destination": "/admin-unavailable.html", "permanent": false },
    { "source": "/admin/",             "destination": "/admin-unavailable.html", "permanent": false },
    { "source": "/admin/:path*",       "destination": "/admin-unavailable.html", "permanent": false }
  ],
  "rewrites": [
    { "source": "/favicon.ico",                   "destination": "/Spill.png" },
    { "source": "/apple-touch-icon.png",          "destination": "/Spill.png" },
    { "source": "/apple-touch-icon-precomposed.png", "destination": "/Spill.png" },
    { "source": "/api/contact",                   "destination": "/api/contact" }
  ]
}
